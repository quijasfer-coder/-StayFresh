# Supabase
# Crea un proyecto en https://supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role solo en server (no NEXT_PUBLIC). Usado únicamente por el
# webhook de WhatsApp (lib/supabase/service.ts) para leer clients/pickups
# sin sesión de usuario — nunca lo expongas al navegador.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# WhatsApp Cloud API (Meta) — dejar vacío hasta completar el setup manual
# descrito en el README (Meta Business Manager, verificación, número
# dedicado, token permanente, plantilla aprobada). Mientras estén vacías,
# el envío de mensajes queda inerte (loguea un warning, no falla).
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_API_VERSION=v21.0

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
